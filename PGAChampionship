<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>🔺 TKE 🔺 PGA Championship Pool 2026</title>
<style>
:root{
  --green:#173b2c;
  --green-dark:#102a1f;
  --green-soft:#28503d;
  --gold:#efe2b8;
  --gold-light:#faf5e4;
  --paper:#fcfaf4;
  --ink:#1e241f;
  --muted:#697268;
  --border:rgba(16,42,31,.10);
  --line:rgba(16,42,31,.08);
  --shadow:0 12px 36px rgba(16,42,31,.07);
}

@keyframes firstPlacePulse{
  0%,100%{ box-shadow:0 0 0 0 rgba(212,175,55,.00), inset 0 0 0 0 rgba(255,230,120,.00); }
  50%{ box-shadow:0 0 0 4px rgba(212,175,55,.18), 0 0 22px rgba(212,175,55,.40); }
}

*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;
  font-family:Arial, Helvetica, sans-serif;
  background:
    radial-gradient(circle at top, rgba(239,226,184,.28), transparent 28%),
    linear-gradient(180deg,#fcfaf4 0%,#f6f2e8 100%);
  color:var(--ink);
}
.page{
  width:100%;
  margin:0;
  padding:0;
}
.full-bleed{
  width:100%;
}
.hero{
  position:relative;
  border-top:2px solid #000;
  border-bottom:2px solid #000;
  overflow:hidden;
  background:linear-gradient(135deg,var(--green) 0%,var(--green-dark) 100%);
  color:#fff;
  border-radius:0;
  padding:34px 0 40px;
  box-shadow:var(--shadow);
  margin:0 0 18px;
}
.hero-inner{
  width:min(1520px, calc(100vw - 40px));
  margin:0 auto;
  text-align:center;
}
.hero::before{
  content:"";
  position:absolute;
  inset:0;
  background:
    radial-gradient(circle at 88% 10%, rgba(255,255,255,.10), transparent 20%),
    linear-gradient(180deg, rgba(255,255,255,.05), transparent 42%);
  pointer-events:none;
}
.hero h1{
  position:relative;
  margin:0;
  font-family:"Playfair Display", Georgia, "Times New Roman", serif;
  font-size:clamp(2.4rem, 5vw, 4.8rem);
  line-height:.98;
  letter-spacing:-.035em;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}
.title-wrap{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}
.title-dog{
  height:42px;
  width:auto;
  transform:translateY(-2px);
}
.top-tabs{
  position:relative;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:12px;
  width:auto;
  max-width:min(1520px, calc(100vw - 40px));
  margin:0 auto 18px;
  padding:0;
  border:0;
  border-radius:18px;
  background:transparent;
  box-shadow:none;
}
.top-tab-indicator{display:none !important;}
.top-tab{
  appearance:none;
  position:relative;
  z-index:1;
  min-width:148px;
  min-height:46px;
  padding:11px 22px;
  border-radius:999px;
  border:2px solid #000;
  background:linear-gradient(180deg,var(--green) 0%,var(--green-dark) 100%);
  color:#fff;
  font-weight:700;
  font-size:.88rem;
  cursor:pointer;
  letter-spacing:.01em;
  transition:transform .2s ease, filter .2s ease;
  box-shadow:none;
}
.top-tab:hover{
  transform:translateY(-1px);
  filter:brightness(1.03);
}
.top-tab.active{
  filter:brightness(1.05);
}
.tab-panel{display:none}
.tab-panel.active{display:block}
.top-grid{
  display:block !important;
  background:transparent !important;
  padding:0 !important;
  width:min(1180px, calc(100vw - 24px)) !important;
  margin:0 auto !important;
}
.card{
  background:rgba(255,255,255,.84);
  border:2px solid #000;
  border-radius:20px;
  box-shadow:var(--shadow);
  overflow:hidden;
  backdrop-filter:blur(6px);
}
.card-header{
  padding:16px 16px 10px;
}
.card-title{
  margin:0;
  font-size:1.12rem;
  color:var(--green);
  font-family:"Playfair Display", Georgia, "Times New Roman", serif;
  letter-spacing:-.02em;
}
.card-sub{
  margin:5px 0 0;
  font-size:.87rem;
  color:#76663a;
  line-height:1.4;
}

.leaderboard-wrap{padding:0}
.leaderboard-card-full,
.leaderboard-card-clean{
  width:100%;
  max-width:none !important;
  margin:0 !important;
  background:#fff !important;
  border:2px solid #000 !important;
  border-radius:16px !important;
  box-shadow:none !important;
  overflow:hidden !important;
}
.leaderboard-card-clean .card-header{
  padding:0 !important;
}
.leaderboard-card-clean .card-title,
.leaderboard-card-clean .card-sub{
  display:none !important;
}
.leaderboard-table{
  width:100% !important;
  border-collapse:collapse !important;
  table-layout:fixed !important;
  border:0 !important;
  background:#fff !important;
}
.leaderboard-table thead th{
  background:var(--green) !important;
  color:#fff !important;
  padding:14px 10px !important;
  font-size:.8rem !important;
  text-transform:uppercase !important;
  letter-spacing:.08em !important;
  border-bottom:2px solid #000 !important;
  text-align:center;
}
.leaderboard-table td{
  background:transparent !important;
  color:#1f2a22 !important;
  padding:14px 10px !important;
  border-bottom:1px solid #d7d7d7 !important;
  font-size:.96rem !important;
  text-align:center !important;
  font-weight:600 !important;
}
.leaderboard-table tbody tr:last-child td{
  border-bottom:0 !important;
}
.leaderboard-table th:first-child,
.leaderboard-table td:first-child{
  width:34% !important;
  text-align:center !important;
  padding-left:10px !important;
}
.leaderboard-table th:last-child,
.leaderboard-table td:last-child{
  width:12% !important;
  padding-right:10px !important;
}
.leaderboard-table tbody tr:nth-child(even):not(.place-1):not(.place-2):not(.place-3) td{
  background:#fafafa !important;
}
.leaderboard-table .participant-name{
  color:#1a5fb4 !important;
  text-decoration:underline !important;
  font-weight:700 !important;
  display:inline-block !important;
}
.participant-link-inner{
  display:flex !important;
  justify-content:center !important;
  align-items:center !important;
}
.place-1 td,
.place-2 td,
.place-3 td{
  background:transparent !important;
}
.place-1 td:first-child{
  background:linear-gradient(90deg,#fff8dc,#f4e19c) !important;
  font-weight:800 !important;
  border-left:4px solid #d4af37 !important;
}
.place-2 td:first-child{
  background:linear-gradient(90deg,#f3f3f3,#dadada) !important;
  font-weight:700 !important;
  border-left:4px solid #c0c0c0 !important;
}
.place-3 td:first-child{
  background:linear-gradient(90deg,#f4e2d7,#dfa881) !important;
  font-weight:700 !important;
  border-left:4px solid #cd7f32 !important;
}
.place-1 td:first-child .participant-link-inner{
  animation:firstPlacePulse 1.6s ease-in-out infinite !important;
  border-radius:999px;
}

.section-title{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  gap:12px;
  margin:18px auto 12px;
  width:min(1520px, calc(100vw - 40px));
}
.section-title h2{
  margin:0;
  font-family:"Playfair Display", Georgia, "Times New Roman", serif;
  color:var(--green);
  font-size:1.32rem;
}
.section-title p{
  margin:0;
  color:var(--muted);
  font-size:.9rem;
}
.participant-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:16px;
  max-width:none;
  margin:0 auto;
  width:min(1520px, calc(100vw - 40px));
}
.participant-card{overflow:hidden}
.participant-top{
  position:relative;
  background:linear-gradient(135deg,var(--green) 0%,var(--green-dark) 100%);
  color:#fff;
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:14px;
  padding:12px 16px;
}
.participant-top::after{
  content:"";
  position:absolute;
  inset:auto 0 0 0;
  height:1px;
  background:rgba(255,255,255,.08);
}
.participant-title-row{
  display:flex;
  align-items:baseline;
  gap:10px;
  min-width:0;
}
.participant-top h3{
  margin:0;
  font-family:"Playfair Display", Georgia, "Times New Roman", serif;
  font-size:1.35rem;
  line-height:1;
}
.participant-top p{
  margin:0;
  color:rgba(255,255,255,.78);
  font-size:.88rem;
  line-height:1;
  white-space:nowrap;
}
.scorebox{
  margin-left:auto;
  text-align:right;
  min-width:0;
  flex-shrink:0;
}
.scorebox .label{display:none;}
.scorebox .value{
  display:block;
  margin-top:0;
  font-size:2rem;
  line-height:1;
  font-weight:700;
}
.scorebox .subvalue{
  display:block;
  margin-top:4px;
  font-size:.94rem;
  line-height:1;
  font-weight:700;
  color:rgba(255,255,255,.86)
}

.participant-meta{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:0;
  padding:0 16px;
  background:rgba(16,42,31,.025);
  border-bottom:1px solid var(--border);
}
.meta-item{
  padding:12px 8px 11px;
  border-right:1px solid var(--line);
  background:transparent;
}
.meta-item:last-child{border-right:0;}
.meta-k{
  display:block;
  font-size:.65rem;
  text-transform:uppercase;
  letter-spacing:.11em;
  color:var(--muted);
  margin-bottom:4px;
}
.meta-v{
  display:block;
  font-size:1rem;
  font-weight:700;
  color:var(--green);
}

.participant-table-wrap{
  padding:16px 18px 18px;
}
.participant-golfers-table{
  width:100%;
  border:2px solid #000;
  border-collapse:separate;
  border-spacing:0;
  table-layout:auto;
  background:rgba(255,255,255,.98);
  border-radius:16px;
  overflow:hidden;
}
.participant-golfers-table th{
  background:linear-gradient(180deg, rgba(16,42,31,.05), rgba(16,42,31,.02));
  color:var(--green);
  padding:12px 8px;
  font-size:.67rem;
  text-transform:uppercase;
  letter-spacing:.14em;
  text-align:center;
  border-bottom:1px solid var(--border);
}
.participant-golfers-table td{
  padding:12px 8px;
  font-size:.88rem;
  text-align:center;
  border-bottom:1px solid rgba(16,42,31,.07);
}
.participant-golfers-table tbody tr:nth-child(even) td{
  background:#fdfbf6;
}
.participant-golfers-table tbody tr:hover td{
  background:#f5f8f3;
}
.participant-golfers-table td:first-child,
.participant-golfers-table th:first-child{
  text-align:left;
  padding-left:12px;
  width:30%;
}
.participant-golfers-table td:last-child,
.participant-golfers-table th:last-child{
  padding-right:12px;
}
.participant-golfers-table td:not(:first-child),
.participant-golfers-table th:not(:first-child){
  font-size:.83rem;
}
.participant-golfers-table td.counting-live{
  background:#eaf7ea !important;
}
.participant-golfers-table td.counting-penalty{
  background:#fdeaea !important;
}
.participant-golfers-table tbody tr:hover td.counting-live{
  background:#dff1df !important;
}
.participant-golfers-table tbody tr:hover td.counting-penalty{
  background:#f7d6d6 !important;
}

.rules-wrap{
  padding:0 14px 16px;
}
.rule-card{
  border:2px solid #000;
  border-radius:18px;
  background:rgba(255,255,255,.92);
  padding:16px 16px 12px;
  margin-bottom:12px;
  box-shadow:0 8px 24px rgba(16,42,31,.04);
}
.rule-card h3{
  margin:0 0 10px;
  color:#174230;
  font-family:"Playfair Display", Georgia, "Times New Roman", serif;
  font-size:1.05rem;
}
.rule-card p,.rule-card li{
  color:#455148;
  line-height:1.55;
  font-size:.94rem;
}
.rule-card ul{
  margin:0;
  padding-left:18px;
}

.hero,
.top-tabs,
.card,
.participant-card,
.rule-card,
.leaderboard-table,
.participant-golfers-table{
  border:2px solid #000 !important;
}

.score-under{color:#0a7a43}
.score-even{color:#425047}
.score-over{color:#8a3928}

@media (min-width:1100px){
  .participant-grid{grid-template-columns:1fr 1fr;}
  .participant-card{min-height:100%;}
}
@media (max-width:720px){
  .page{padding:10px}
  .leaderboard-table th,.leaderboard-table td{padding:9px 4px;font-size:.8rem}
  .leaderboard-table th:first-child,.leaderboard-table td:first-child{width:30%}
  .participant-meta{grid-template-columns:1fr 1fr}
}
@media (max-width:520px){
  .top-tabs{
    width:calc(100vw - 20px);
    max-width:calc(100vw - 20px);
    gap:6px;
  }
  .top-tab{
    min-width:112px;
    min-height:38px;
    padding:8px 12px;
    font-size:.8rem;
    flex:1 1 0;
  }
  .hero{padding:20px 16px;border-radius:20px}
  .leaderboard-table th,.leaderboard-table td{padding:8px 3px;font-size:.77rem}
  .leaderboard-table th:first-child,.leaderboard-table td:first-child{width:31%}
  .participant-top{
    padding:10px 12px;
    gap:10px;
  }
  .participant-title-row{
    gap:8px;
    min-width:0;
  }
  .participant-top h3{font-size:1.12rem}
  .participant-top p{font-size:.76rem;}
  .scorebox .value{font-size:1.55rem}
  .scorebox .subvalue{font-size:.82rem;}
  .participant-table-wrap{padding:12px 10px 14px;}
  .participant-golfers-table th{
    padding:9px 4px;
    font-size:.58rem;
    letter-spacing:.1em;
  }
  .participant-golfers-table td{
    padding:9px 4px;
    font-size:.75rem;
  }
  .participant-golfers-table td:first-child,
  .participant-golfers-table th:first-child{
    width:44%;
    padding-left:8px;
  }
  .participant-golfers-table td:nth-child(2),
  .participant-golfers-table th:nth-child(2){
    width:10%;
    padding-left:3px;
  }
  .participant-golfers-table td:not(:first-child),
  .participant-golfers-table th:not(:first-child){
    font-size:.68rem;
  }
}
@media (max-width:700px){
  .top-grid{ width:calc(100vw - 14px) !important; }
  .leaderboard-table thead th,
  .leaderboard-table td{
    padding:12px 6px !important;
    font-size:.86rem !important;
  }
  .leaderboard-table th:first-child,
  .leaderboard-table td:first-child{ width:40% !important; }
  .leaderboard-table th:last-child,
  .leaderboard-table td:last-child{ width:14% !important; }
}
</style>
