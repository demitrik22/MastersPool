<script>
document.addEventListener('DOMContentLoaded', function () {
  const DATA_URL = "https://script.google.com/macros/s/AKfycbwbqpGDuDYHy34TMxDbbSM37w0yFvClWmejrJGgMnCpTAPJfW1FaawDet29-WIVgSWpiw/exec";
  const REFRESH_MS = 30000;

  const tabs = document.querySelectorAll('.top-tab');
  const panels = document.querySelectorAll('.tab-panel');
  const trendChart = document.getElementById('trend-chart');
  const trendLegend = document.getElementById('trend-legend');
  const trendNote = document.getElementById('trend-note');
  const standingsBody = document.getElementById('pool-standings-tbody');
  const participantGrid = document.getElementById('participant-grid');
  const leaderboardSub = document.querySelector('.leaderboard-card-clean .card-sub');

  let latestParticipants = [];

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      const targetId = tab.getAttribute('data-tab-target');
      tabs.forEach(function(t) {
        t.classList.remove('active');
        t.removeAttribute('aria-current');
      });
      panels.forEach(function(p) { p.classList.remove('active'); });
      tab.classList.add('active');
      tab.setAttribute('aria-current', 'page');
      const panel = document.getElementById(targetId);
      if (panel) {
        panel.classList.add('active');
        if (targetId === 'pool-view') setTimeout(renderChart, 30);
        setTimeout(function() {
          panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 50);
      }
    });
  });

  function slugify(value) {
    return String(value || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  }

  function parseNumber(value, fallback = 0) {
    if (value === null || value === undefined || value === '') return fallback;
    const cleaned = String(value).replace(/,/g, '').trim();
    const num = Number(cleaned);
    return Number.isFinite(num) ? num : fallback;
  }

  function parseToPar(value) {
    const str = String(value || '').trim().toUpperCase();
    if (!str || str === '—') return 999;
    if (str === 'E') return 0;
    const num = Number(str.replace('+', ''));
    return Number.isFinite(num) ? num : 999;
  }

  function formatThru(value, status) {
    const str = String(value || '').trim();
    if (!str || str === '0') {
      if (status === 'Missed Cut') return 'MC';
      if (status === 'Scheduled') return '—';
      return '—';
    }
    return str;
  }

  function scoreClass(toPar) {
    const num = parseToPar(toPar);
    if (num < 0) return 'score-under';
    if (num === 0) return 'score-even';
    return 'score-over';
  }

  function formatParTotal(num) {
    if (!Number.isFinite(num)) return 'E';
    if (num === 0) return 'E';
    return num > 0 ? ('+' + num) : String(num);
  }

  function isPenaltyStatus(status) {
    const normalized = String(status || '').trim().toLowerCase();
    return normalized === 'missed cut' || normalized === 'mc' || normalized === 'cut' || normalized === 'withdrawn' || normalized === 'wd' || normalized === 'dq' || normalized === 'disqualified';
  }

  function isCompletedRoundStroke(value) {
    const num = parseNumber(value, null);
    return Number.isFinite(num) && num >= 50 && num <= 120;
  }

  function getPenaltyStrokeCount(golfer) {
    if (!isPenaltyStatus(golfer.status)) return 0;

    const normalized = String(golfer.status || '').trim().toLowerCase();

    if (normalized === 'missed cut' || normalized === 'mc' || normalized === 'cut') {
      return 2;
    }

    return ['r1', 'r2', 'r3', 'r4'].reduce(function(total, key) {
      return total + (isCompletedRoundStroke(golfer[key]) ? 0 : 1);
    }, 0);
  }

  function getEffectiveGolferTotal(golfer) {
    return parseNumber(golfer.golfer_total, 9999) + (getPenaltyStrokeCount(golfer) * 10);
  }

  function getEffectiveRoundScore(golfer, roundKey) {
    const numericValue = parseNumber(golfer[roundKey], null);
    const isPenalty = isPenaltyStatus(golfer.status);

    if (!isPenalty) {
      return isCompletedRoundStroke(numericValue) ? numericValue : Infinity;
    }

    const normalized = String(golfer.status || '').trim().toLowerCase();

    if (normalized === 'missed cut' || normalized === 'mc' || normalized === 'cut') {
      if (roundKey === 'r1' || roundKey === 'r2') {
        return isCompletedRoundStroke(numericValue) ? numericValue : Infinity;
      }
      return isCompletedRoundStroke(numericValue) ? numericValue : 82;
    }

    return isCompletedRoundStroke(numericValue) ? numericValue : 10;
  }

  function getRoundCountingIds(participant, roundKey) {
    return new Set(
      participant.golfers
        .slice()
        .map(function(g) {
          return {
            golfer_id: g.golfer_id,
            score: getEffectiveRoundScore(g, roundKey)
          };
        })
        .filter(function(item) {
          return Number.isFinite(item.score);
        })
        .sort(function(a, b) {
          return a.score - b.score;
        })
        .slice(0, 6)
        .map(function(item) { return item.golfer_id; })
    );
  }

  function buildRoundCountingMap(participant) {
    participant.roundCounting = {
      r1: getRoundCountingIds(participant, 'r1'),
      r2: getRoundCountingIds(participant, 'r2'),
      r3: getRoundCountingIds(participant, 'r3'),
      r4: getRoundCountingIds(participant, 'r4')
    };
  }

  function isCountedInRound(participant, golfer, roundKey) {
    return !!(
      participant &&
      participant.roundCounting &&
      participant.roundCounting[roundKey] &&
      participant.roundCounting[roundKey].has(golfer.golfer_id)
    );
  }

  function isCountedAnywhere(participant, golfer) {
    return ['r1', 'r2', 'r3', 'r4'].some(function(roundKey) {
      return isCountedInRound(participant, golfer, roundKey);
    });
  }

  function isPenaltyRound(golfer, roundKey) {
    if (!isPenaltyStatus(golfer.status)) return false;

    const normalized = String(golfer.status || '').trim().toLowerCase();

    if (normalized === 'missed cut' || normalized === 'mc' || normalized === 'cut') {
      return roundKey === 'r3' || roundKey === 'r4';
    }

    return !isCompletedRoundStroke(golfer[roundKey]);
  }

  function getParticipantRoundStrokeTotal(participant, roundKey) {
    return participant.golfers.reduce(function(sum, golfer) {
      return sum + (isCountedInRound(participant, golfer, roundKey)
        ? getEffectiveRoundScore(golfer, roundKey)
        : 0);
    }, 0);
  }

  function getRoundPenaltyToPar(golfer, roundKey) {
    if (!isPenaltyStatus(golfer.status)) return null;

    const normalized = String(golfer.status || '').trim().toLowerCase();
    if (normalized === 'missed cut' || normalized === 'mc' || normalized === 'cut') {
      return (roundKey === 'r3' || roundKey === 'r4') ? 10 : null;
    }

    if (isCompletedRoundStroke(golfer[roundKey])) {
      return parseNumber(golfer[roundKey], 0) - 72;
    }

    return 10;
  }

  function getGolferRoundToPar(golfer, roundKey) {
    const penaltyToPar = getRoundPenaltyToPar(golfer, roundKey);
    if (penaltyToPar !== null) return penaltyToPar;

    if (isCompletedRoundStroke(golfer[roundKey])) {
      return parseNumber(golfer[roundKey], 0) - 72;
    }

    return 0;
  }

  function getParticipantRoundToPar(participant, roundKey) {
    return participant.golfers.reduce(function(sum, golfer) {
      return sum + (isCountedInRound(participant, golfer, roundKey)
        ? getGolferRoundToPar(golfer, roundKey)
        : 0);
    }, 0);
  }

  function getCountingToParTotal(participant) {
    return (
      getParticipantRoundToPar(participant, 'r1') +
      getParticipantRoundToPar(participant, 'r2') +
      getParticipantRoundToPar(participant, 'r3') +
      getParticipantRoundToPar(participant, 'r4')
    );
  }

  function getCountingStrokeTotal(participant) {
    return (
      parseNumber(participant.participant_r1, 0) +
      parseNumber(participant.participant_r2, 0) +
      parseNumber(participant.participant_r3, 0) +
      parseNumber(participant.participant_r4, 0)
    );
  }

  function applyDerivedParticipantTotals(participant) {
    buildRoundCountingMap(participant);

    participant.participant_r1 = getParticipantRoundStrokeTotal(participant, 'r1');
    participant.participant_r2 = getParticipantRoundStrokeTotal(participant, 'r2');
    participant.participant_r3 = getParticipantRoundStrokeTotal(participant, 'r3');
    participant.participant_r4 = getParticipantRoundStrokeTotal(participant, 'r4');

    participant.adjusted_total = getCountingStrokeTotal(participant);
  }

  function getDisplayedScoreToPar(participant, golfer) {
    if (isCountedAnywhere(participant, golfer) && isPenaltyStatus(golfer.status)) {
      const baseToPar = parseToPar(golfer.to_par);
      const adjustedToPar = (Number.isFinite(baseToPar) && baseToPar < 900 ? baseToPar : 0) + (getPenaltyStrokeCount(golfer) * 10);
      return formatParTotal(adjustedToPar);
    }
    if (golfer.status === 'Missed Cut') return 'MC';
    return golfer.to_par;
  }

  function displayedScoreClass(participant, golfer) {
    if (isCountedAnywhere(participant, golfer) && isPenaltyStatus(golfer.status)) {
      const baseToPar = parseToPar(golfer.to_par);
      const adjustedToPar = (Number.isFinite(baseToPar) && baseToPar < 900 ? baseToPar : 0) + (getPenaltyStrokeCount(golfer) * 10);
      return scoreClass(adjustedToPar);
    }
    return scoreClass(golfer.to_par);
  }

  function roundCellClass(participant, golfer, roundKey) {
    if (!isCountedInRound(participant, golfer, roundKey)) return '';
    return isPenaltyRound(golfer, roundKey) ? 'counting-penalty' : 'counting-live';
  }

  function roundCellValue(golfer, roundKey) {
    const value = golfer[roundKey];
    return value === null || value === undefined || value === '' ? '—' : value;
  }

  function buildParticipants(rows) {
    const grouped = new Map();

    rows.forEach(function(row) {
      const id = row.participant_id;
      if (!grouped.has(id)) {
        grouped.set(id, {
          participant_id: id,
          participant_name: row.participant_name,
          rank: parseNumber(row.rank, 999),
          participant_r1: parseNumber(row.participant_r1),
          participant_r2: parseNumber(row.participant_r2),
          participant_r3: parseNumber(row.participant_r3),
          participant_r4: parseNumber(row.participant_r4),
          Cuts: parseNumber(row.Cuts),
          adjusted_total: parseNumber(row.adjusted_total),
          thru_total: parseNumber(row.thru_total),
          thru_t6: parseNumber(row.thru_t6),
          t6_remaining_holes: parseNumber(row.t6_remaining_holes),
          golfers: []
        });
      }

      grouped.get(id).golfers.push({
        golfer_id: row.golfer_id,
        golfer_name: row.golfer_name,
        to_par: row.to_par,
        Live_Score: row.Live_Score,
        thru: row.thru,
        status: row.status,
        r1: row.r1,
        r2: row.r2,
        r3: row.r3,
        r4: row.r4,
        golfer_total: row.golfer_total
      });
    });

    const participants = Array.from(grouped.values()).sort(function(a, b) {
      if (a.rank !== b.rank) return a.rank - b.rank;
      return a.adjusted_total - b.adjusted_total;
    });

    participants.forEach(function(participant) {
      participant.golfers.forEach(function(golfer) {
        golfer.penalty_strokes = getPenaltyStrokeCount(golfer) * 10;
        golfer.effective_total = getEffectiveGolferTotal(golfer);
      });

      participant.golfers.sort(function(a, b) {
        return a.effective_total - b.effective_total;
      });

      applyDerivedParticipantTotals(participant);
    });

    participants.sort(function(a, b) {
      if (a.adjusted_total !== b.adjusted_total) return a.adjusted_total - b.adjusted_total;
      if (a.participant_r1 !== b.participant_r1) return a.participant_r1 - b.participant_r1;
      return String(a.participant_name).localeCompare(String(b.participant_name));
    });

    participants.forEach(function(participant, index) {
      participant.rank = index + 1;
    });

    return participants;
  }

  function renderStandings(participants) {
    standingsBody.innerHTML = participants.map(function(p, index) {
      const medalClass = index === 0 ? 'place-1' : index === 1 ? 'place-2' : index === 2 ? 'place-3' : '';
      const round1Total = getParticipantRoundToPar(p, 'r1');
      const round2Total = getParticipantRoundToPar(p, 'r2');
      const round3Total = getParticipantRoundToPar(p, 'r3');
      const round4Total = getParticipantRoundToPar(p, 'r4');
      const round1Score = formatParTotal(round1Total);
      const round2Score = formatParTotal(round2Total);
      const round3Score = formatParTotal(round3Total);
      const round4Score = formatParTotal(round4Total);
      const totalScore = getCountingToParTotal(p);

      return '<tr class="' + medalClass + '">' +
        '<td><a href="#' + slugify(p.participant_name) + '" class="participant-name"><span class="participant-link-inner"><span>' + p.participant_name + '</span></span></a></td>' +
        '<td class="' + scoreClass(round1Score) + '">' + round1Score + '</td>' +
        '<td class="' + scoreClass(round2Score) + '">' + round2Score + '</td>' +
        '<td class="' + scoreClass(round3Score) + '">' + round3Score + '</td>' +
        '<td class="' + scoreClass(round4Score) + '">' + round4Score + '</td>' +
        '<td class="' + (totalScore < 0 ? 'score-under' : totalScore > 0 ? 'score-over' : 'score-even') + '">' + formatParTotal(totalScore) + '</td>' +
      '</tr>';
    }).join('');

    if (leaderboardSub) {
      leaderboardSub.textContent = 'Live participant standings shown as score to par by round and total.';
    }
  }

  function participantSubtitle(rank) {
    if (rank === 1) return 'Rank 1';
    return 'Rank ' + rank;
  }

  function renderParticipants(participants) {
    participantGrid.innerHTML = participants.map(function(p) {
      return '<article class="card participant-card">' +
        '<div class="participant-top">' +
          '<div class="participant-title-row">' +
            '<h3 id="' + slugify(p.participant_name) + '">' + p.participant_name + '</h3>' +
            '<p>' + participantSubtitle(p.rank) + '</p>' +
          '</div>' +
          '<div class="scorebox">' +
            '<span class="value">' + getCountingStrokeTotal(p) + '</span>' +
            '<span class="subvalue">(' + formatParTotal(getCountingToParTotal(p)) + ')</span>' +
          '</div>' +
        '</div>' +
        '<div class="participant-meta">' +
          '<div class="meta-item"><span class="meta-k">Round 1</span><span class="meta-v">' + p.participant_r1 + '</span></div>' +
          '<div class="meta-item"><span class="meta-k">Round 2</span><span class="meta-v">' + p.participant_r2 + '</span></div>' +
          '<div class="meta-item"><span class="meta-k">Thru T6</span><span class="meta-v">' + p.thru_t6 + '</span></div>' +
          '<div class="meta-item"><span class="meta-k">Remaining</span><span class="meta-v">' + p.t6_remaining_holes + '</span></div>' +
        '</div>' +
        '<div class="participant-table-wrap">' +
          '<table class="participant-golfers-table">' +
            '<thead><tr><th>Golfer</th><th>Thru</th><th>R1</th><th>R2</th><th>R3</th><th>R4</th><th>Score</th><th>Total</th></tr></thead>' +
            '<tbody>' +
              p.golfers.map(function(g) {
                return '<tr>' +
                  '<td>' + g.golfer_name + '</td>' +
                  '<td>' + formatThru(g.thru, g.status) + '</td>' +
                  '<td class="' + roundCellClass(p, g, 'r1') + '">' + roundCellValue(g, 'r1') + '</td>' +
                  '<td class="' + roundCellClass(p, g, 'r2') + '">' + roundCellValue(g, 'r2') + '</td>' +
                  '<td class="' + roundCellClass(p, g, 'r3') + '">' + roundCellValue(g, 'r3') + '</td>' +
                  '<td class="' + roundCellClass(p, g, 'r4') + '">' + roundCellValue(g, 'r4') + '</td>' +
                  '<td class="' + displayedScoreClass(p, g) + '">' + getDisplayedScoreToPar(p, g) + '</td>' +
                  '<td>' + (Number.isFinite(g.effective_total) && g.effective_total < 9999 ? g.effective_total : (g.golfer_total || '—')) + '</td>' +
                '</tr>';
              }).join('') +
            '</tbody>' +
          '</table>' +
        '</div>' +
      '</article>';
    }).join('');
  }

  function renderChart() {
    if (!trendChart || !trendLegend || !trendNote) return;
  }

  function renderAll(rows) {
    latestParticipants = buildParticipants(rows);
    renderStandings(latestParticipants);
    renderParticipants(latestParticipants);
    renderChart();
  }

  async function loadData() {
    try {
      const response = await fetch(DATA_URL, { cache: 'no-store' });
      const rows = await response.json();
      if (!Array.isArray(rows) || !rows.length) throw new Error('No rows returned');
      renderAll(rows);
    } catch (error) {
      console.error('Failed to load live data:', error);
      if (leaderboardSub) leaderboardSub.textContent = 'Unable to load live data right now.';
      if (trendNote) trendNote.textContent = 'Live feed unavailable.';
    }
  }

  loadData();
  setInterval(loadData, REFRESH_MS);
});
</script>

</body>
</html>
