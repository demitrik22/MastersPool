          <table class="leaderboard-table">
            <thead>
              <tr>
                <th>Participant</th>
                <th>R1</th>
                <th>R2</th>
                <th>R3</th>
                <th>R4</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody id="pool-standings-tbody"></tbody>
          </table>
        </div>
      </article>
    </section>

    <div class="section-title">
      <h2>Participant Scoreboards</h2>
      <p></p>
    </div>

    <section class="participant-grid" id="participant-grid"></section>
