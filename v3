<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>🔺 TKE 🔺 Masters Pool 2026</title>
<style>
:root{
  --green:#173b2c;
  --green-dark:#102a1f;
  --green-soft:#28503d;
  --gold:#efe2b8;
  --gold-light:#faf5e4;
  --paper:#fcfaf4;
  --ink:#1e241f;
  --muted:#697268;
  --border:rgba(16,42,31,.10);
  --line:rgba(16,42,31,.08);
  --shadow:0 12px 36px rgba(16,42,31,.07);
}

@keyframes firstPlacePulse{
  0%,100%{ box-shadow:0 0 0 0 rgba(212,175,55,.00), inset 0 0 0 0 rgba(255,230,120,.00); }
  50%{ box-shadow:0 0 0 4px rgba(212,175,55,.18), 0 0 22px rgba(212,175,55,.40); }
}

*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;
  font-family:Arial, Helvetica, sans-serif;
  background:
    radial-gradient(circle at top, rgba(239,226,184,.28), transparent 28%),
    linear-gradient(180deg,#fcfaf4 0%,#f6f2e8 100%);
  color:var(--ink);
}
.page{
  width:100%;
  margin:0;
  padding:0;
}
.dashboard-shell{
  width:min(1520px, calc(100vw - 40px));
  margin:0 auto;
}
.full-bleed{
  width:100%;
}
.section-shell{
  width:min(1520px, calc(100vw - 40px));
  margin:0 auto;
}
.hero{
  position:relative;
  border-top:2px solid #000;
  border-bottom:2px solid #000;
  overflow:hidden;
  background:linear-gradient(135deg,var(--green) 0%,var(--green-dark) 100%);
  color:#fff;
  border-radius:0;
  padding:34px 0 40px;
  box-shadow:var(--shadow);
  margin:0 0 18px;
}
.hero-inner{
  width:min(1520px, calc(100vw - 40px));
  margin:0 auto;
  text-align:center;
}
.hero::before{
  content:"";
  position:absolute;
  inset:0;
  background:
    radial-gradient(circle at 88% 10%, rgba(255,255,255,.10), transparent 20%),
    linear-gradient(180deg, rgba(255,255,255,.05), transparent 42%);
  pointer-events:none;
}
.eyebrow{
  position:relative;
  display:inline-flex;
  align-items:center;
  padding:7px 11px;
  border-radius:999px;
  border:1px solid rgba(255,255,255,.12);
  background:rgba(255,255,255,.07);
  font-size:.68rem;
  text-transform:uppercase;
  letter-spacing:.17em;
  opacity:.92;
  margin-bottom:12px;
}
.hero h1{
  position:relative;
  margin:0;
  font-family:"Playfair Display", Georgia, "Times New Roman", serif;
  font-size:clamp(2.4rem, 5vw, 4.8rem);
  line-height:.98;
  letter-spacing:-.035em;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}

.title-wrap{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}

.title-dog{
  height:42px;
  width:auto;
  transform:translateY(-2px);
}
.top-tabs{
  position:relative;
  border:2px solid #000;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:10px;
  width:fit-content;
  max-width:min(1520px, calc(100vw - 40px));
  margin:0 auto 18px;
  padding:6px;
  border:1px solid var(--border);
  border-radius:18px;
  background:rgba(255,255,255,.92);
  box-shadow:0 8px 22px rgba(16,42,31,.04);
}
.top-tab-indicator{
  position:absolute;
  top:6px;
  left:6px;
  height:calc(100% - 12px);
  border-radius:14px;
  background:linear-gradient(180deg,var(--green-soft) 0%,var(--green-dark) 100%);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.10), 0 8px 18px rgba(16,42,31,.12);
  transition:left .3s ease, width .3s ease, transform .3s ease;
  z-index:0;
  pointer-events:none;
}
.top-tab{
  appearance:none;
  position:relative;
  z-index:1;
  border:0;
  background:transparent;
  color:var(--green);
  min-width:140px;
  min-height:42px;
  padding:9px 18px;
  border-radius:12px;
  font-weight:700;
  font-size:.88rem;
  cursor:pointer;
  letter-spacing:.01em;
  transition:color .25s ease, transform .2s ease;
}
.top-tab:hover{
  transform:translateY(-1px);
}
.top-tab.active{
  color:#f7f1de;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.08);
}
.tab-panel{display:none}
.tab-panel.active{display:block}
.top-grid{
  display:grid;
  grid-template-columns:1.1fr .9fr;
  gap:14px;
  align-items:start;
}
.card{
  background:rgba(255,255,255,.84);
  border:2px solid #000;
  border-radius:20px;
  box-shadow:var(--shadow);
  overflow:hidden;
  backdrop-filter:blur(6px);
}
.strip-card{
  background:linear-gradient(180deg,var(--gold-light) 0%,var(--gold) 100%);
  border-color:rgba(115,86,20,.14);
}
.card-header{
  padding:16px 16px 10px;
}
.card-title{
  margin:0;
  font-size:1.12rem;
  color:var(--green);
  font-family:"Playfair Display", Georgia, "Times New Roman", serif;
  letter-spacing:-.02em;
}
.card-sub{
  margin:5px 0 0;
  font-size:.87rem;
  color:#76663a;
  line-height:1.4;
}

.summary-card{
  background:rgba(255,255,255,.86);
}
.summary-card .card-header{
  padding-bottom:6px;
}

.leaderboard-card{
  width:100%;
  margin:0 auto;
}
.trends-card{
  width:100%;
  margin:18px auto 0;
}
@media (min-width:1025px){
  .leaderboard-card .card-header,
  .trends-card .card-header{
    padding:20px 22px 12px;
  }
  .leaderboard-wrap{
    padding:0 12px 14px;
  }
  .leaderboard-table th{
    padding:12px 8px;
    font-size:.74rem;
  }
  .leaderboard-table td{
    padding:13px 8px;
    font-size:.94rem;
  }
  .trends-card .trend-toolbar{
    padding:0 22px 10px;
  }
  .trends-card .trend-legend{
    padding:0 22px 12px;
  }
  .trends-card .trend-chart-wrap{
    padding:0 18px 18px 12px;
    height:300px;
  }
  .trends-card .trend-chart{
    height:100%;
  }
}
.trend-toolbar{
  display:block;
  padding:0 16px 8px;
}
.trend-note{
  font-size:.77rem;
  line-height:1.35;
  color:#677166;
}
.trend-legend{
  display:flex;
  flex-wrap:wrap;
  gap:8px 14px;
  padding:0 16px 10px;
}
.legend-item{
  display:inline-flex;
  align-items:center;
  gap:8px;
  color:#556055;
  font-size:.79rem;
}
.legend-line{
  width:18px;
  height:0;
  border-top:3px solid currentColor;
  border-radius:999px;
  display:inline-block;
}
.trend-chart-wrap{
  width:100%;
  height:280px;
  padding:0 22px 20px;
}
.trend-chart{
  width:100%;
  height:100%;
  display:block;
}

.axis-line{
  stroke:rgba(16,42,31,.26);
  stroke-width:1.3;
}
.grid-line{
  stroke:rgba(16,42,31,.08);
  stroke-width:1;
}
.axis-label,.round-label{
  fill:#6c766c;
  font-size:11px;
  font-family:Arial, Helvetica, sans-serif;
}
.trend-line{
  fill:none;
  stroke-width:2.3;
  stroke-linecap:round;
  stroke-linejoin:round;
}
.dot{ stroke:#fff; stroke-width:1.4; }

.leaderboard-wrap{padding:0 0 6px}

.leaderboard-card-full,
.trends-card-full{
  width:100%;
}
.top-grid{
  grid-template-columns:1fr;
}
.pool-trends-section{
  margin-top:16px;
}
.trends-card-full .trend-chart-wrap{
  padding:4px 16px 18px 8px;
  min-height:360px;
}
.trends-card-full .trend-chart{
  height:360px;
}
@media (min-width:1025px){
  body{
    background:
      radial-gradient(circle at top, rgba(239,226,184,.24), transparent 30%),
      linear-gradient(180deg,#faf7ee 0%,#f2ede0 100%);
  }
  .page{
    max-width:1520px;
    padding:20px 22px 34px;
  }
  .hero{
    border-radius:30px;
    padding:34px 34px 30px;
    margin-bottom:18px;
    box-shadow:0 18px 44px rgba(16,42,31,.10);
  }
  .top-tabs{
    margin:0 0 18px;
    padding:5px;
    border-radius:18px;
    background:rgba(255,255,255,.78);
  }
  .card,
  .strip-card,
  .summary-card,
  .participant-card,
  .all-golfers-card,
  .rule-card{
    border-radius:26px;
    box-shadow:0 16px 42px rgba(16,42,31,.08);
  }
  .leaderboard-card-full,
  .trends-card-full,
  .all-golfers-card,
  .rules-wrap,
  .participant-grid,
  .section-title{
    width:100%;
    max-width:none;
  }
  .leaderboard-card-full .card-header,
  .trends-card-full .card-header,
  .all-golfers-card .card-header{
    padding:24px 26px 12px;
  }
  .leaderboard-card-full .card-title,
  .trends-card-full .card-title,
  .section-title h2{
    font-size:1.55rem;
  }
  .leaderboard-wrap{
    padding:0 0 10px;
  }
  .leaderboard-table th,
  .leaderboard-table td{
    padding-top:14px;
    padding-bottom:14px;
    font-size:.94rem;
  }
  .leaderboard-table th{
    font-size:.75rem;
  }
  .leaderboard-table td:first-child,
  .leaderboard-table th:first-child{
    width:34%;
    padding-left:20px;
  }
  .leaderboard-table td:last-child,
  .leaderboard-table th:last-child{
    padding-right:20px;
    width:16%;
  }
  .pool-trends-section{
    margin-top:18px;
  }
  .trends-card-full .trend-toolbar,
  .trends-card-full .trend-legend{
    padding-left:26px;
    padding-right:26px;
  }
  .trends-card-full .trend-chart-wrap{
    padding:8px 20px 24px 10px;
    height:320px;
  }
  .trends-card-full .trend-chart{
    height:100%;
  }
  .section-title{
    margin:24px 2px 14px;
    padding:0 6px;
  }
  .participant-grid{
    gap:18px;
  }
  .participant-card{
    border-radius:28px;
  }
  .participant-top{
    padding:16px 20px;
  }
  .participant-top h3{
    font-size:1.55rem;
  }
  .scorebox .value{
    font-size:2.35rem;
  }
  .participant-meta{
    grid-template-columns:repeat(4,minmax(0,1fr));
    padding:0 20px;
  }
  .meta-item{
    padding:14px 10px 13px;
  }
  .meta-v{
    font-size:1.08rem;
  }
  .participant-table-wrap{
    padding:18px 20px 22px;
  }
  .participant-golfers-table{
    border-radius:18px;
  }
  .participant-golfers-table th{
    padding:14px 10px;
    font-size:.69rem;
  }
  .participant-golfers-table td{
    padding:14px 10px;
    font-size:.9rem;
  }
  .espn-wrap{
    padding:0 16px 16px;
  }
  .espn-board{
    min-width:100%;
    border-radius:18px;
  }
}

.leaderboard-table{
  width:100%;
  border:2px solid #000;
  border-collapse:collapse;
  table-layout:fixed;
}
.leaderboard-table th{
  background:linear-gradient(180deg,var(--green-soft) 0%,var(--green-dark) 100%);
  color:#f7efcf;
  padding:10px 6px;
  font-size:.72rem;
  text-transform:uppercase;
  letter-spacing:.12em;
  text-align:center;
}
.leaderboard-table td{
  padding:10px 6px;
  font-size:.88rem;
  text-align:center;
  border-bottom:1px solid rgba(107,81,24,.14);
  color:#3a311b;
  font-weight:600;
}
.leaderboard-table td:first-child,
.leaderboard-table th:first-child{
  text-align:left;
  padding-left:12px;
  width:29%;
}
.leaderboard-table td:last-child,
.leaderboard-table th:last-child{
  padding-right:12px;
  width:12%;
}
.leaderboard-table tbody tr:nth-child(even) td{
  background:rgba(255,255,255,.15);
}
.leaderboard-table .participant-name{
  color:#1a5fb4;
  text-decoration:underline;
  font-weight:700;
}
.leaderboard-table .participant-name:hover{
  color:#0d3f8a;
  text-decoration:underline;
}
.participant-link-inner{
  display:flex;
  justify-content:center;
  align-items:center;
}
.place-1 td:first-child{border-left:4px solid #d4af37}
.place-2 td:first-child{border-left:4px solid #c0c0c0}
.place-3 td:first-child{border-left:4px solid #cd7f32}

.section-title{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  gap:12px;
  margin:18px 2px 12px;
}
.section-title h2{
  margin:0;
  font-family:"Playfair Display", Georgia, "Times New Roman", serif;
  color:var(--green);
  font-size:1.32rem;
}
.section-title p{
  margin:0;
  color:var(--muted);
  font-size:.9rem;
}
.participant-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:16px;
  max-width:none;
  margin:0;
}
.participant-card{overflow:hidden}
.participant-top{
  position:relative;
  background:linear-gradient(135deg,var(--green) 0%,var(--green-dark) 100%);
  color:#fff;
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:14px;
  padding:12px 16px;
}
.participant-top::after{
  content:"";
  position:absolute;
  inset:auto 0 0 0;
  height:1px;
  background:rgba(255,255,255,.08);
}
.participant-title-row{
  display:flex;
  align-items:baseline;
  gap:10px;
  min-width:0;
}
.participant-top h3{
  margin:0;
  font-family:"Playfair Display", Georgia, "Times New Roman", serif;
  font-size:1.35rem;
  line-height:1;
}
.participant-top p{
  margin:0;
  color:rgba(255,255,255,.78);
  font-size:.88rem;
  line-height:1;
  white-space:nowrap;
}
.scorebox{
  margin-left:auto;
  text-align:right;
  min-width:0;
  flex-shrink:0;
}
.scorebox .label{
  display:none;
}
.scorebox .value{
  display:block;
  margin-top:0;
  font-size:2rem;
  line-height:1;
  font-weight:700;
}
.scorebox .subvalue{display:block;margin-top:4px;font-size:.94rem;line-height:1;font-weight:700;color:rgba(255,255,255,.86)}

.participant-meta{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:0;
  padding:0 16px;
  background:rgba(16,42,31,.025);
  border-bottom:1px solid var(--border);
}
.meta-item{
  padding:12px 8px 11px;
  border-right:1px solid var(--line);
  background:transparent;
}
.meta-item:last-child{
  border-right:0;
}
.meta-k{
  display:block;
  font-size:.65rem;
  text-transform:uppercase;
  letter-spacing:.11em;
  color:var(--muted);
  margin-bottom:4px;
}
.meta-v{
  display:block;
  font-size:1rem;
  font-weight:700;
  color:var(--green);
}
.golfer-list{
  padding:12px;
  display:grid;
  gap:9px;
}
.golfer-row{
  border:1px solid var(--border);
  border-radius:14px;
  padding:10px;
  background:linear-gradient(180deg,rgba(255,255,255,.95),rgba(248,246,239,.95));
}
.golfer-row.counting{
  background:linear-gradient(180deg,rgba(238,250,242,.98),rgba(247,251,248,.96));
  border-color:rgba(10,122,67,.26);
}
.golfer-head{
  display:flex;
  justify-content:space-between;
  gap:10px;
  align-items:flex-start;
  margin-bottom:9px;
}
.golfer-name{margin:0;font-size:.98rem;font-weight:700}
.golfer-badges{
  display:flex;
  flex-wrap:wrap;
  gap:6px;
  margin-top:5px;
}
.badge{
  display:inline-flex;
  align-items:center;
  border:1px solid var(--border);
  border-radius:999px;
  padding:4px 7px;
  font-size:.68rem;
  text-transform:uppercase;
  letter-spacing:.07em;
  background:#fff;
  color:#546055;
}
.badge.live{background:rgba(17,66,48,.08);color:var(--green)}
.badge.counting{background:rgba(10,122,67,.10);color:#0a7a43;border-color:rgba(10,122,67,.18)}
.golfer-right{text-align:right;min-width:62px}
.position{font-size:.72rem;text-transform:uppercase;letter-spacing:.11em;color:var(--muted)}
.to-par{margin-top:4px;font-size:1.08rem;font-weight:700}
.score-under{color:#0a7a43}
.score-even{color:#425047}
.score-over{color:#8a3928}
.golfer-stats{
  display:grid;
  grid-template-columns:repeat(6,1fr);
  gap:7px;
}
.stat{
  border:1px solid var(--border);
  border-radius:11px;
  padding:7px 6px;
  text-align:center;
  background:rgba(255,255,255,.74);
}
.stat-label{
  display:block;
  font-size:.58rem;
  text-transform:uppercase;
  letter-spacing:.12em;
  color:var(--muted);
  margin-bottom:4px;
}
.stat-value{display:block;font-size:.9rem;font-weight:700}

.participant-table-wrap{
  padding:16px 18px 18px;
}
.participant-golfers-table{
  width:100%;
  border:2px solid #000;
  border-collapse:separate;
  border-spacing:0;
  table-layout:auto;
  background:rgba(255,255,255,.98);
  border:1px solid var(--border);
  border-radius:16px;
  overflow:hidden;
}
.participant-golfers-table th{
  background:linear-gradient(180deg, rgba(16,42,31,.05), rgba(16,42,31,.02));
  color:var(--green);
  padding:12px 8px;
  font-size:.67rem;
  text-transform:uppercase;
  letter-spacing:.14em;
  text-align:center;
  border-bottom:1px solid var(--border);
}
.participant-golfers-table td{
  padding:12px 8px;
  font-size:.88rem;
  text-align:center;
  border-bottom:1px solid rgba(16,42,31,.07);
}
.participant-golfers-table tbody tr:nth-child(even) td{
  background:#fdfbf6;
}
.participant-golfers-table tbody tr:hover td{
  background:#f5f8f3;
}
.participant-golfers-table tbody tr.counting-live td{
  background:#eaf7ea;
}
.participant-golfers-table tbody tr.counting-live:nth-child(even) td{
  background:#e3f3e3;
}
.participant-golfers-table tbody tr.counting-penalty td{
  background:#fdeaea;
}
.participant-golfers-table tbody tr.counting-penalty:nth-child(even) td{
  background:#fbe1e1;
}
.participant-golfers-table tbody tr.counting-live:hover td{
  background:#dff1df;
}
.participant-golfers-table tbody tr.counting-penalty:hover td{
  background:#f7d6d6;
}
.participant-golfers-table td:first-child,
.participant-golfers-table th:first-child{
  text-align:left;
  padding-left:12px;
  width:30%;
}
.participant-golfers-table td:last-child,
.participant-golfers-table th:last-child{
  padding-right:12px;
}
.participant-golfers-table td:not(:first-child),
.participant-golfers-table th:not(:first-child){
  font-size:.83rem;
}
.participant-golfers-table td.counting-live{
  background:#eaf7ea !important;
}
.participant-golfers-table td.counting-penalty{
  background:#fdeaea !important;
}
.participant-golfers-table tbody tr:hover td.counting-live{
  background:#dff1df !important;
}
.participant-golfers-table tbody tr:hover td.counting-penalty{
  background:#f7d6d6 !important;
}

.refresh-note{
  margin:14px 3px 0;
  font-size:.85rem;
  color:#667067;
}
.all-golfers-card{overflow:hidden}
.espn-wrap{
  width:100%;
  overflow-x:auto;
  -webkit-overflow-scrolling:touch;
  padding:0 10px 12px;
}
.espn-board{
  min-width:860px;
  border:2px solid #000;
  width:100%;
  border-collapse:collapse;
  background:#fff;
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
}
.espn-board th{
  background:linear-gradient(180deg,var(--green-soft) 0%,var(--green-dark) 100%);
  color:#f7efcf;
  padding:11px 10px;
  font-size:.72rem;
  text-transform:uppercase;
  letter-spacing:.12em;
  white-space:nowrap;
  text-align:center;
}
.espn-board td{
  padding:11px 10px;
  font-size:.92rem;
  text-align:center;
  border-bottom:1px solid rgba(17,50,35,.08);
  white-space:nowrap;
}
.espn-board td:nth-child(2),
